    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  const row = item.json;\n\n  let riskScore = 0;\n  let redFlags = [];\n\n  // Rule 1\n  // High Declared Value\n\n  if (row.declared_value_usd > 100000) {\n    riskScore += 20;\n    redFlags.push(\"High declared transaction value\");\n  }\n\n  // Rule 2\n  // Large Quantity\n\n  if (row.quantity > 50000) {\n    riskScore += 15;\n    redFlags.push(\"Unusually large shipment quantity\");\n  }\n\n  // Rule 3\n  // High-Risk Countries\n\n  const highRiskCountries = [\n    \"Iran\",\n    \"North Korea\",\n    \"Afghanistan\",\n    \"Syria\"\n  ];\n\n  if (\n    highRiskCountries.includes(row.origin_country) ||\n    highRiskCountries.includes(row.destination_country)\n  ) {\n    riskScore += 30;\n    redFlags.push(\"High-risk country involved\");\n  }\n\n  // Rule 4\n  // Cash Payment\n\n  if (\n    row.payment_terms &&\n    row.payment_terms.toLowerCase().includes(\"cash\")\n  ) {\n    riskScore += 20;\n    redFlags.push(\"Cash payment\");\n  }\n\n  // Rule 5\n  // Open Account\n\n  if (\n    row.payment_terms &&\n    row.payment_terms.toLowerCase().includes(\"open\")\n  ) {\n    riskScore += 10;\n    redFlags.push(\"Open account payment\");\n  }\n\n  // Risk Level\n\n  let riskLevel = \"Low\";\n\n  if (riskScore >= 60) {\n    riskLevel = \"High\";\n  } else if (riskScore >= 30) {\n    riskLevel = \"Medium\";\n  }\n\n  // Recommendation\n\n  let recommendation = \"No immediate action\";\n\n  if (riskLevel === \"Medium\") {\n    recommendation = \"Conduct enhanced review\";\n  }\n\n  if (riskLevel === \"High\") {\n    recommendation = \"Escalate for investigation\";\n  }\n\n  return {\n\n    json: {\n\n      ...row,\n\n      risk_score: riskScore,\n\n      risk_level: riskLevel,\n\n      red_flags: redFlags,\n\n      recommendation: recommendation\n\n    }\n\n  };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2464,
        144
      ],
      "id": "b642ce61-cdd2-4826-a969-ca1d59c35e84",
      "name": "⚖️ TBML Rule Engine"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n    const row = item.json;\n\n    let unitPrice = 0;\n\n    if (Number(row.quantity) > 0) {\n\n        unitPrice = Number(row.declared_value_usd) / Number(row.quantity);\n\n    }\n\n    return {\n\n        json: {\n\n            ...row,\n\n            calculated_unit_price: Number(unitPrice.toFixed(2))\n\n        }\n\n    };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2160,
        144
      ],
      "id": "a013ad77-f9ad-4c35-a929-5476971a8b23",
      "name": "💲 Unit Price Calculator"
    },
    {
      "parameters": {
        "jsCode": "const highRiskCountries = [\n  \"Iran\",\n  \"North Korea\",\n  \"Syria\",\n  \"Afghanistan\",\n  \"Myanmar\"\n];\n\nreturn items.map(item => {\n\n    const row = item.json;\n\n    let countryRisk = \"Low\";\n\n    let countryScore = 0;\n\n    let countryFlag = \"\";\n\n    if (\n        highRiskCountries.includes(row.origin_country) ||\n        highRiskCountries.includes(row.destination_country)\n    ) {\n\n        countryRisk = \"High\";\n\n        countryScore = 30;\n\n        countryFlag = \"High-Risk Jurisdiction\";\n\n    }\n\n    return {\n\n        json: {\n\n            ...row,\n\n            country_risk: countryRisk,\n\n            country_score: countryScore,\n\n            country_flag: countryFlag\n\n        }\n\n    };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2064,
        -576
      ],
      "id": "16c55f54-3b86-44fa-ad92-2d780472073a",
      "name": "🌍 Country Risk Assessment"
    },
    {
      "parameters": {
        "jsCode": "// Count how many times each record_id appears\nconst recordCounts = {};\n\nfor (const item of items) {\n  const id = item.json.record_id;\n  recordCounts[id] = (recordCounts[id] || 0) + 1;\n}\n\nreturn items.map(item => {\n\n  const row = item.json;\n\n  const duplicate = recordCounts[row.record_id] > 1;\n\n  return {\n    json: {\n      ...row,\n\n      duplicate_record: duplicate,\n\n      duplicate_score: duplicate ? 20 : 0,\n\n      duplicate_flag: duplicate\n        ? \"Duplicate Record ID Detected\"\n        : \"\"\n    }\n  };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1840,
        -576
      ],
      "id": "94192c73-251a-4e49-a925-dfe017d31a55",
      "name": "🔍 Duplicate Transaction Detection"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n    const row = item.json;\n\n    // Existing scores\n    const baseScore = Number(row.risk_score || 0);\n    const countryScore = Number(row.country_score || 0);\n    const duplicateScore = Number(row.duplicate_score || 0);\n\n    // Pricing score\n    let pricingScore = 0;\n\n    if (row.pricing_flag === \"Possible Over-Invoicing\") {\n        pricingScore = 25;\n    }\n\n    if (row.pricing_flag === \"Possible Under-Invoicing\") {\n        pricingScore = 25;\n    }\n\n    // Calculate total score\n    const finalScore =\n        baseScore +\n        countryScore +\n        duplicateScore +\n        pricingScore;\n\n    // Determine risk level\n    let finalRisk = \"Low\";\n\n    if (finalScore >= 20)\n        finalRisk = \"Medium\";\n\n    if (finalScore >= 50)\n        finalRisk = \"High\";\n\n    if (finalScore >= 80)\n        finalRisk = \"Critical\";\n\n    // Investigation priority\n    let priority = \"Routine\";\n\n    if (finalRisk === \"Medium\")\n        priority = \"Review\";\n\n    if (finalRisk === \"High\")\n        priority = \"Urgent\";\n\n    if (finalRisk === \"Critical\")\n        priority = \"Immediate\";\n\n    // Recommendation\n    let recommendation = \"No further action.\";\n\n    switch (finalRisk) {\n\n        case \"Medium\":\n            recommendation =\n                \"Perform Enhanced Due Diligence (EDD).\";\n            break;\n\n        case \"High\":\n            recommendation =\n                \"Refer to Senior Investigator.\";\n            break;\n\n        case \"Critical\":\n            recommendation =\n                \"Immediate investigation and STR review.\";\n            break;\n    }\n\n    return {\n\n        json: {\n\n            ...row,\n\n            pricing_score: pricingScore,\n\n            final_risk_score: finalScore,\n\n            final_risk_level: finalRisk,\n\n            investigation_priority: priority,\n\n            final_recommendation: recommendation\n\n        }\n\n    };\n\n});"
      },
